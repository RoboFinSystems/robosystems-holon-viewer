# =============================================================================
# ROBOSYSTEMS HOLON VIEWER — LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# Copy to .env (gitignored) and adjust. Vite reads every VITE_* var here into
# both the dev server (proxy target) and production builds.
#   cp .env.example .env
# =============================================================================

# RoboSystems API base URL for SEC Mode.
#   - `npm run dev`: the dev server proxies /v1/* to this target (server-side,
#     dodging the API's localhost-less CORS allowlist), so point it at your local
#     backend to develop against localhost. Defaults to https://api.robosystems.ai
#     when unset.
#   - production build: the client calls this URL directly, so its CORS allowlist
#     must include the viewer's deployed origin.
# VITE_ROBOSYSTEMS_API_URL=http://localhost:8000

# Opt-in: resolve @robosystems/report-components to a sibling checkout's dist
# (../robosystems-report-components/dist) to exercise unpublished render changes.
# Requires a fresh `npm run build` in that repo. Set to true to enable.
# VITE_LOCAL_REPORT_COMPONENTS=true

# Public equity-research portal. The SEC report page links out to
# <base>/<ticker> when the ticker appears in the catalog. Both default to the
# public CDN / site, so these only need setting to point at a staging portal.
# VITE_RESEARCH_CATALOG_URL=https://assets.robosystems.ai/content/index.json
# VITE_RESEARCH_BASE_URL=https://robosystems.ai/research
